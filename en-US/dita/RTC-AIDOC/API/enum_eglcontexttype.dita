<?xml version='1.0' encoding='UTF-8'?>
<!DOCTYPE reference PUBLIC "-//OASIS//DTD DITA Reference//EN" "reference.dtd">
<reference id="enum_eglcontexttype">
    <title><ph keyref="EGL_CONTEXT_TYPE"/></title>
    <shortdesc id="short"><ph id="shortdesc" props="cpp">EGL context type.</ph></shortdesc>
    <refbody>
        <section id="detailed_desc" deliveryTarget="details" otherprops="no-title" props="cpp">
            <p props="cpp">Defines different types of EGL contexts, corresponding to different OpenGL interface implementations.</p>
        </section>
        <section id="parameters" deliveryTarget="details" props="cpp">
            <title>Enumerations</title>
            <parml>
                <plentry props="cpp">
                    <pt>EGL_CONTEXT10</pt>
                    <pd>(0): Uses the OpenGL interface defined by Khronos (<codeph>javax.microedition.khronos.egl.*</codeph>).</pd>
                </plentry>
                <plentry props="cpp">
                    <pt>EGL_CONTEXT14</pt>
                    <pd>(1): Uses the OpenGL interface defined by Android (<codeph>android.opengl.*</codeph>).</pd>
                </plentry>
            </parml>
        </section>
    </refbody>
</reference>