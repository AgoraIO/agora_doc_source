<?xml version='1.0' encoding='UTF-8'?>
<!DOCTYPE reference PUBLIC "-//OASIS//DTD DITA Reference//EN" "reference.dtd">
<reference id="api_irtcengine_pushaudioframe2">
    <title><ph keyref="pushAudioFrame2"/></title>
    <shortdesc id="short"><ph id="shortdesc" props="android">Pushes external audio frame to the SDK.</ph></shortdesc>
    <prolog>
        <metadata>
            <keywords>
                <indexterm keyref="pushAudioFrame2"/>
            </keywords>
        </metadata>
    </prolog>
    <refbody>
        <section id="prototype">
            <p outputclass="codeblock">
                <codeblock props="android" outputclass="language-java">public abstract int pushExternalAudioFrame(byte[] data, long timestamp, int sampleRate, int channels, Constants.BytesPerSample bytesPerSample, int trackId);</codeblock>
            </p>
        </section>
        <section id="detailed_desc" deliveryTarget="details" otherprops="no-title">
            <p props="android">Before calling this method, follow these steps:
                <ol>
                    <li>Call <xref keyref="createCustomAudioTrack"/> to create a custom audio track and get the track ID.</li>
                    <li>Call <codeph>joinChannel</codeph> to join the channel. In <xref keyref="ChannelMediaOptions"/>, set <codeph>publishCustomAudioTrackId</codeph> to the track ID and set <codeph>publishCustomAudioTrack</codeph> to <xref keyref="true"/>.</li>
                </ol>
            </p>
        </section>
        <section id="timing" deliveryTarget="details" props="android">
            <title>Timing</title>
            <p props="android">Before calling this method to push external audio data, complete the following steps:
                <ol>
                    <li>Call <xref keyref="createCustomAudioTrack"/> to create a custom audio track and get the track ID.</li>
                    <li>Call <codeph>joinChannel</codeph> to join the channel. In <xref keyref="ChannelMediaOptions"/>, set <codeph>publishCustomAudioTrackId</codeph> to the track ID and set <codeph>publishCustomAudioTrack</codeph> to <xref keyref="true"/>.</li>
                </ol>
            </p>
        </section>
        <section id="parameters" deliveryTarget="details" props="android">
            <title>Parameters</title>
            <parml>
                <plentry props="android">
                    <pt>data</pt>
                    <pd>External audio data.</pd>
                </plentry>
                <plentry props="android">
                    <pt>timestamp</pt>
                    <pd>Timestamp of the external audio frame (ms). This parameter is required and can be used to restore the order of captured audio frames or to achieve audio-video sync in scenarios involving video (including external video sources).</pd>
                </plentry>
                <plentry props="android">
                    <pt>sampleRate</pt>
                    <pd>Sample rate (Hz) of the external audio source. Available values:
                        <ul>
                            <li><codeph>8000</codeph></li>
                            <li><codeph>16000</codeph></li>
                            <li><codeph>32000</codeph></li>
                            <li><codeph>44100</codeph></li>
                            <li><codeph>48000</codeph>.</li>
                        </ul>
                    </pd>
                </plentry>
                <plentry props="android">
                    <pt>channels</pt>
                    <pd>Number of channels in the external audio source. Available values:
                        <ul>
                            <li><codeph>1</codeph>: Mono.</li>
                            <li><codeph>2</codeph>: Stereo.</li>
                        </ul>
                    </pd>
                </plentry>
                <plentry props="android">
                    <pt>bytesPerSample</pt>
                    <pd>Number of bytes per sample.</pd>
                </plentry>
                <plentry props="android">
                    <pt>trackId</pt>
                    <pd>Audio track ID. Set this to the custom audio track ID returned by <xref keyref="createCustomAudioTrack"/>.</pd>
                </plentry>
            </parml>
        </section>
        <section id="return_values" props="android">
            <title>Return Values</title>
            <p props="android">
                <ul>
                    <li>0: Success.</li>
                    <li>&lt; 0: Failure.</li>
                </ul>
            </p>
        </section>
    </refbody>
</reference>