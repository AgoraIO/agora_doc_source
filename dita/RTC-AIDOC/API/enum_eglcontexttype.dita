<?xml version='1.0' encoding='UTF-8'?>
<!DOCTYPE reference PUBLIC "-//OASIS//DTD DITA Reference//EN" "reference.dtd">
<reference id="enum_eglcontexttype">
    <title><ph keyref="EGL_CONTEXT_TYPE"/></title>
    <shortdesc id="short"><ph id="shortdesc" props="cpp">EGL 上下文类型。</ph></shortdesc>
    <refbody>
        <section id="detailed_desc" deliveryTarget="details" otherprops="no-title" props="cpp">
            <p props="cpp">定义了 EGL 上下文的不同类型，对应不同的 OpenGL 接口实现。</p>
        </section>
        <section id="parameters" deliveryTarget="details" props="cpp">
            <title>枚举值</title>
            <parml>
                <plentry props="cpp">
                    <pt>EGL_CONTEXT10</pt>
                    <pd>（0）：使用 Khronos 定义的 OpenGL 接口 (<codeph>javax.microedition.khronos.egl.*</codeph>)。</pd>
                </plentry>
                <plentry props="cpp">
                    <pt>EGL_CONTEXT14</pt>
                    <pd>（1）：使用 Android 定义的 OpenGL 接口 (<codeph>android.opengl.*</codeph>)。</pd>
                </plentry>
            </parml>
        </section>
    </refbody>
</reference>